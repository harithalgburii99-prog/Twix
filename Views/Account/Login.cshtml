@model Twix.ViewModels.LoginViewModel
@{ ViewBag.Title = "Sign In · Twix"; Layout = "_Layout"; }

<div class="auth-wrap">
  <div class="auth-card">
    <div class="auth-logo">𝕿</div>
    <h1 class="auth-title">Sign in to Twix</h1>

    <form asp-action="Login" method="post">
      @Html.AntiForgeryToken()
      <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl"/>
      <div asp-validation-summary="All" class="val-summary"></div>

      <label class="field-label">Email</label>
      <input asp-for="Email" class="input" placeholder="you@example.com" autocomplete="email"/>
      <span asp-validation-for="Email" class="field-error"></span>

      <label class="field-label">Password</label>
      <input asp-for="Password" type="password" class="input" placeholder="••••••••" autocomplete="current-password"/>
      <span asp-validation-for="Password" class="field-error"></span>

      <label class="checkbox-row">
        <input asp-for="RememberMe" type="checkbox"/>
        <span>Remember me</span>
      </label>

      <button type="submit" class="btn btn-primary btn-full">Sign In →</button>
    </form>

    <p class="auth-link">No account? <a href="/Account/Register">Sign up</a></p>
    <p class="auth-hint">Demo: <strong>demo@twix.app</strong> / <strong>Demo123!</strong></p>
    <p class="auth-hint">Admin: <strong>admin@twix.app</strong> / <strong>Admin123!</strong></p>
  </div>
</div>
